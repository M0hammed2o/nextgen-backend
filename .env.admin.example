# ═══════════════════════════════════════════════════════════════════════════════
# NextGen AI Platform — Admin API (.env.admin)
# IMPORTANT: Admin API DOES need WhatsApp token because it imports
# backend.app.bot.whatsapp_sender at runtime for the test-send feature.
# ═══════════════════════════════════════════════════════════════════════════════
DEBUG=true
ENVIRONMENT=development
ALLOWED_ORIGINS=https://admin.nextgenintelligence.co.za,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174,http://localhost:5175

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nextgen
REDIS_URL=redis://redis:6379/0

# If your AdminSettings expects these
API_V1_PREFIX=/v1/admin
APP_VERSION=1.0.0

# JWT (must match backend)
JWT_SECRET_KEY=CHANGE-ME-generate-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Meta / WhatsApp ──────────────────────────────────────────────────────────
# Required: the admin_api imports backend.app.bot.whatsapp_sender at runtime.
# That module calls get_settings() (backend Settings) which reads env vars.
# If these are missing the token defaults to "CHANGE-ME" and Meta calls fail.
WHATSAPP_DEFAULT_ACCESS_TOKEN=your_system_user_access_token_here
META_API_VERSION=v22.0
META_API_BASE_URL=https://graph.facebook.com
META_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your_meta_app_secret
