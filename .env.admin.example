# ═══════════════════════════════════════════════════════════════════════════════
# NextGen AI Platform — Admin API (.env.admin)
# Admin API does NOT need WhatsApp token.
# ═══════════════════════════════════════════════════════════════════════════════
DEBUG=true
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nextgen
REDIS_URL=redis://redis:6379/0

# If your AdminSettings expects these
API_V1_PREFIX=/v1/admin
APP_VERSION=1.0.0

# JWT (must match backend)
JWT_SECRET_KEY=CHANGE-ME-generate-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
