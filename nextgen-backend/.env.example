# ═══════════════════════════════════════════════════════════════════════════════
# NextGen AI Platform — Environment Variables (Model 1)
# Copy to .env.backend (backend) or .env.admin (admin API).
# Never commit real credentials to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
ALLOWED_ORIGINS=https://nextgenintelligence.co.za,https://app.nextgenintelligence.co.za,https://staff.nextgenintelligence.co.za,https://admin.nextgenintelligence.co.za,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nextgen
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT (CHANGE IN PRODUCTION) ───────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-generate-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Meta / WhatsApp Cloud API (Model 1: Platform Token) ─────────────────────
# From Meta Developer Portal → Your App → WhatsApp → Configuration
WHATSAPP_DEFAULT_ACCESS_TOKEN=YOUR_SYSTEM_USER_TOKEN_HERE
META_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v22.0
META_API_BASE_URL=https://graph.facebook.com
WHATSAPP_WEBHOOK_PATH=/v1/webhook/meta

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.3

# ── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_STORAGE_BUCKET=nextgen-assets

# ── Rate Limiting ────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_PER_MINUTE=5
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
CUSTOMER_MESSAGE_RATE_PER_MINUTE=10
