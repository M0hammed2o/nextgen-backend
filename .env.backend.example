# ═══════════════════════════════════════════════════════════════════════════════
# NextGen AI Platform — Backend (.env.backend)
# Model 1: Single WABA, Multiple Phone Numbers
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
ALLOWED_ORIGINS=https://nextgenintelligence.co.za,https://app.nextgenintelligence.co.za,https://staff.nextgenintelligence.co.za,https://admin.nextgenintelligence.co.za,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── Database / Redis ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nextgen
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
REDIS_URL=redis://redis:6379/0

# ── JWT (generate a real key for production) ─────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-generate-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ═══════════════════════════════════════════════════════════════════════════════
# META / WHATSAPP (Model 1: Single WABA, Platform Token)
#
# Architecture:
#   ONE Meta App → ONE WhatsApp Business Account (WABA)
#   ONE System User Access Token (long-lived, from Meta Business Manager)
#   MULTIPLE phone_number_id values (one per client business, stored in DB)
#
# The access token is platform-level, NOT per-business.
# Each business only has a whatsapp_phone_number_id in the businesses table.
# ═══════════════════════════════════════════════════════════════════════════════
WHATSAPP_DEFAULT_ACCESS_TOKEN=your_system_user_access_token_here
META_VERIFY_TOKEN=your_webhook_verify_token
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v22.0
META_API_BASE_URL=https://graph.facebook.com
WHATSAPP_WEBHOOK_PATH=/v1/webhook/meta

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.3

# ── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_STORAGE_BUCKET=nextgen-assets

# ── Rate Limiting ────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_PER_MINUTE=5
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
CUSTOMER_MESSAGE_RATE_PER_MINUTE=10
