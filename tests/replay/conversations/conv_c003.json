{
  "id": "conv_c003",
  "title": "Cancel vs edit — 'Actually never mind' clears cart (CANCEL)",
  "category": "cancel_restart",
  "tags": ["deterministic", "order_cancel", "cart_cleared"],

  "notes": "ORDER_CANCEL scenario via keyword: 'Actually never mind' contains 'never mind' which matches ORDER_CANCEL intent — cart is cleared and session resets to IDLE. Next order starts with an empty cart. Verifies 'Burger → Actually never mind → Chicken → Chicken only'.",

  "turns": [
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Classic Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "Actually never mind",
      "expect": {
        "state": "IDLE",
        "cart": [],
        "response_contains": ["cancel"]
      }
    },
    {
      "message": "Can I get a Spicy Chicken Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Spicy Chicken Burger", "quantity": 1}],
        "response_contains": ["spicy chicken"]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Zanele",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0829876543",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Spicy Chicken Burger", "quantity": 1}],
    "subtotal_cents": 8000,
    "total_cents": 8000,
    "order_mode": "PICKUP",
    "customer_name": "Zanele"
  }
}
