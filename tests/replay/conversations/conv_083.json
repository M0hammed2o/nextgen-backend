{
  "id": "conv_083",
  "title": "Confirmation — Confirm after multiple edits (add then deterministic remove then add)",
  "category": "confirmation",
  "tags": ["deterministic", "confirmation", "cart_edit", "pickup"],

  "notes": "All three cart operations are deterministic. 'Remove the chips' is intercepted by DET_REMOVE_CART — Chips is a named menu item in the cart. No LLM is called in this conversation.",

  "turns": [
    {
      "message": "Can I get a Classic Smash Burger and Chips",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Chips", "quantity": 1}
        ],
        "confirmed_cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Chips", "quantity": 1}
        ]
      }
    },
    {
      "message": "Remove the chips",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Classic Smash Burger", "quantity": 1}],
        "confirmed_cart": [{"name": "Classic Smash Burger", "quantity": 1}],
        "response_contains": ["removed"]
      }
    },
    {
      "message": "Add a Coca-Cola (330ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Coca-Cola (330ml)", "quantity": 1}
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Dineo",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0711000020",
      "expect": {"state": "ORDER_PLACED"}
    }
  ],

  "final_order": {
    "items": [
      {"name": "Classic Smash Burger", "quantity": 1},
      {"name": "Coca-Cola (330ml)", "quantity": 1}
    ],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP"
  }
}
