    "modifier_editing"
  ],
  "notes": "Regression for BUG 3. Cart has Burger + Extra Cheese. Customer says 'remove the extra cheese on the Loaded Smash Burger'. The _is_reference_not_target guard recognises the burger as a reference (preceded by 'on the'), so DET_A2 does NOT remove it. Instead DET_B2 detects Extra Cheese as the paid add-on target and removes it. Burger survives.",
  "menu": [
    "Loaded Smash Burger"
  ],
  "turns": [
    {
      "message": "Loaded Smash Burger with extra cheese",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Loaded Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Remove the extra cheese on the Loaded Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Loaded Smash Burger",
            "quantity": 1
          }
        ],
        "response_contains": [
          "removed"
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Andile",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0867890123",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Loaded Smash Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Andile"
  }
}