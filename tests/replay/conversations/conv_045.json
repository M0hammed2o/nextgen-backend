{
  "id": "conv_045",
  "title": "Pickup — only name required (no phone)",
  "category": "pickup",
  "tags": ["deterministic", "pickup", "name_only"],

  "business": {
    "delivery_enabled": false,
    "require_customer_name": true,
    "require_phone_number": false
  },

  "turns": [
    {
      "message": "Can I get an Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Ice Coffee", "quantity": 1}]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Xolani",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Ice Coffee", "quantity": 1}],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Xolani"
  }
}
