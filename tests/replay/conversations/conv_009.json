{
  "id": "conv_009",
  "title": "Hello + order in same message — greeting+DET combined response",
  "category": "mixed_intent",
  "tags": ["deterministic", "greeting_with_order", "regression_failure_4"],

  "turns": [
    {
      "message": "Hello can I please get an Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Ice Coffee", "quantity": 1}],
        "confirmed_cart": [{"name": "Ice Coffee", "quantity": 1}],
        "response_contains": ["ice coffee", "welcome"]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Mohammed",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0837866021",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Ice Coffee", "quantity": 1}],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP"
  }
}
