{
  "id": "conv_c004",
  "title": "Cancel regression — 'No thanks' clears cart, new order starts fresh",
  "category": "cancel_restart",
  "tags": ["deterministic", "cancel", "negate", "cart_clear"],

  "notes": "'No thanks' was previously not caught by is_negation, falling through to LLM which returned chitchat without clearing the cart. With the fix it is caught deterministically, cart is cleared, and the new order starts fresh.",

  "turns": [
    {
      "message": "Can I get a Double Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Double Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "No thanks",
      "expect": {
        "state": "IDLE",
        "cart": [],
        "response_contains": ["cancelled"]
      }
    },
    {
      "message": "Can I get an Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Ice Coffee", "quantity": 1}],
        "response_contains": ["ice coffee"]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Sipho",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0834567890",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Ice Coffee", "quantity": 1}],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Sipho"
  }
}
