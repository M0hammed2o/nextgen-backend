{
  "id": "conv_048",
  "title": "Recovery — start over mid-order clears cart",
  "category": "recovery",
  "tags": ["deterministic", "start_over", "cancel"],

  "turns": [
    {
      "message": "Can I get a Classic Smash Burger and 2 Cokes",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Coca-Cola (330ml)", "quantity": 2}
        ]
      }
    },
    {
      "message": "Start over",
      "expect": {
        "state": "IDLE",
        "cart": [],
        "response_contains": ["cancel"]
      }
    },
    {
      "message": "Can I get an Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Ice Coffee", "quantity": 1}],
        "response_not_contains": ["classic smash burger"]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Dumisani",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0730000001",
      "expect": {"state": "ORDER_PLACED"}
    }
  ],

  "final_order": {
    "items": [{"name": "Ice Coffee", "quantity": 1}],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP"
  }
}
