{
  "id": "conv_103",
  "title": "SA slang — sho, 2 spicy chicken brgrs pls",
  "category": "sa_slang",
  "tags": ["llm", "sa_slang", "normalizer"],

  "notes": "sho → 'sure' via normalizer. pls → 'please'. 'spicy chicken brgrs' — LLM interprets brgrs as burgers. 'sure' triggers ORDER_CONFIRM intent but cart is empty so it falls to LLM.",

  "turns": [
    {
      "message": "Sho, 2 spicy chicken brgrs pls",
      "llm": {
        "action": "add_items",
        "message": "Added 2x Spicy Chicken Burger to your order ✅",
        "items": [{"name": "Spicy Chicken Burger", "quantity": 2}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Spicy Chicken Burger", "quantity": 2}]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Siyabonga",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0821000008",
      "expect": {"state": "ORDER_PLACED"}
    }
  ],

  "final_order": {
    "items": [{"name": "Spicy Chicken Burger", "quantity": 2}],
    "subtotal_cents": 16000,
    "total_cents": 16000,
    "order_mode": "PICKUP"
  }
}
