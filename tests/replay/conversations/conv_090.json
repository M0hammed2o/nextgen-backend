{
  "id": "conv_090",
  "title": "Delivery — Explicit accept fee (Ok to fee), then Card payment",
  "category": "delivery",
  "tags": ["deterministic", "delivery", "delivery_fee", "card"],

  "business": {
    "delivery_enabled": true,
    "require_customer_name": false,
    "require_phone_number": false,
    "require_delivery_address": false
  },

  "turns": [
    {
      "message": "Can I get a Double Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Double Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Delivery please",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "88 Main Road, Rondebosch",
      "expect": {
        "state": "WAITING_DELIVERY_FEE_APPROVAL",
        "cart": []
      }
    },
    {
      "_type": "staff_action",
      "description": "Staff sets delivery fee R35",
      "context_updates": {
        "delivery_fee_cents": 3500,
        "delivery_fee_status": "FEE_SENT"
      }
    },
    {
      "message": "Ok",
      "expect": {
        "state": "COLLECTING_PAYMENT",
        "response_contains": ["cash", "card"]
      }
    },
    {
      "message": "Card",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],

  "final_order": {
    "items": [{"name": "Double Smash Burger", "quantity": 1}],
    "subtotal_cents": 9500,
    "delivery_fee_cents": 3500,
    "total_cents": 13000,
    "order_mode": "DELIVERY",
    "payment_status": "PENDING"
  }
}
