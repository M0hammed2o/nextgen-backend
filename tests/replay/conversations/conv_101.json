{
  "id": "conv_101",
  "title": "SA slang — Eish bru, cud I get a grilled chicken brgr",
  "category": "sa_slang",
  "tags": ["llm", "sa_slang", "normalizer"],

  "notes": "cud normalises to 'could'. 'brgr' is SA shorthand — LLM maps it to Grilled Chicken Burger.",

  "turns": [
    {
      "message": "Eish bru, cud I get a grilled chicken brgr",
      "llm": {
        "action": "add_items",
        "message": "Added Grilled Chicken Burger to your order ✅",
        "items": [{"name": "Grilled Chicken Burger", "quantity": 1}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Grilled Chicken Burger", "quantity": 1}]
      }
    },
    {
      "message": "Yebo",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Ntombi",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0821000006",
      "expect": {"state": "ORDER_PLACED"}
    }
  ],

  "final_order": {
    "items": [{"name": "Grilled Chicken Burger", "quantity": 1}],
    "subtotal_cents": 8500,
    "total_cents": 8500,
    "order_mode": "PICKUP"
  }
}
