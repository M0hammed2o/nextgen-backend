{
  "id": "conv_c002",
  "title": "Cancel vs edit — 'No' keeps cart (EDIT), then add item",
  "category": "cancel_restart",
  "tags": ["deterministic", "order_edit", "cart_preserved"],

  "notes": "ORDER_EDIT scenario: customer says 'No' (soft negation) in CONFIRMING_ORDER. Cart must be PRESERVED and state returns to BUILDING_CART. Customer then adds a Coke — the original burger must still be in the cart alongside the Coke. Verifies 'Burger → No → Add Coke → Burger remains'.",

  "turns": [
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Classic Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "No",
      "expect": {
        "state": "BUILDING_CART",
        "cart": [{"name": "Classic Smash Burger", "quantity": 1}],
        "response_contains": ["change"]
      }
    },
    {
      "message": "Add a Coke",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Coca-Cola (330ml)", "quantity": 1}
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Thabo",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0821234567",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [
      {"name": "Classic Smash Burger", "quantity": 1},
      {"name": "Coca-Cola (330ml)", "quantity": 1}
    ],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP",
    "customer_name": "Thabo"
  }
}
