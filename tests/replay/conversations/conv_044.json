{
  "id": "conv_044",
  "title": "Pickup — business does not require name or phone",
  "category": "pickup",
  "tags": ["deterministic", "pickup", "no_details_required"],

  "business": {
    "delivery_enabled": false,
    "require_customer_name": false,
    "require_phone_number": false
  },

  "turns": [
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Classic Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],

  "final_order": {
    "items": [{"name": "Classic Smash Burger", "quantity": 1}],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP"
  }
}
