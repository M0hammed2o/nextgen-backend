{
  "id": "conv_p005",
  "title": "Pricing — multiple paid add-ons on one item (Extra Cheese + Extra Patty)",
  "category": "pricing",
  "tags": ["llm", "pricing", "add_on", "multi_addon", "pickup"],

  "notes": "Extra Cheese R10 + Extra Patty R25 = R35 in add-ons. unit_price=7500+1000+2500=11000. subtotal=11000.",

  "turns": [
    {
      "message": "Loaded Smash Burger with extra cheese and extra patty",
      "llm": {
        "action": "add_items",
        "message": "Loaded Smash Burger with Extra Cheese and Extra Patty — R110.00 ✅",
        "items": [{"name": "Loaded Smash Burger", "quantity": 1, "options": {}, "add_ons": [{"name": "Extra Cheese", "quantity": 1}, {"name": "Extra Patty", "quantity": 1}], "special_instructions": ""}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Loaded Smash Burger", "quantity": 1}],
        "response_contains": ["loaded smash burger"]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Yusuf",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0824567890",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Loaded Smash Burger", "quantity": 1}],
    "subtotal_cents": 11000,
    "total_cents": 11000,
    "order_mode": "PICKUP",
    "customer_name": "Yusuf"
  }
}
