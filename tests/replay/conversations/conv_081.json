{
  "id": "conv_081",
  "title": "Confirmation \u2014 Wait in CONFIRMING_ORDER goes back to BUILDING_CART",
  "category": "confirmation",
  "tags": [
    "deterministic",
    "confirmation",
    "cart_edit"
  ],
  "turns": [
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "No",
      "expect": {
        "state": "BUILDING_CART",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          }
        ],
        "response_contains": [
          "change"
        ]
      }
    },
    {
      "message": "Add a Coca-Cola (330ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          },
          {
            "name": "Coca-Cola (330ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Rethabile",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0711000018",
      "expect": {
        "state": "ORDER_PLACED"
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Classic Smash Burger",
        "quantity": 1
      },
      {
        "name": "Coca-Cola (330ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP"
  }
}