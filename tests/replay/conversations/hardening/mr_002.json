            "options": {},
            "add_ons": [],
            "special_instructions": ""
          }
        ]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          },
          {
            "name": "Onion Rings",
            "quantity": 1
          }
        ],
        "response_contains": [
          "onion rings"
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
