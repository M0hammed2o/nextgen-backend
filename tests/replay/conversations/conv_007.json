{
  "id": "conv_007",
  "title": "Delivery fee flow — PENDING_DELIVERY_FEE → staff sets fee → YES → Cash",
  "category": "delivery",
  "tags": ["deterministic", "delivery", "delivery_fee", "cash"],

  "business": {
    "delivery_enabled": true,
    "require_customer_name": false,
    "require_phone_number": false,
    "require_delivery_address": false
  },

  "turns": [
    {
      "message": "Hello",
      "expect": {"state": "GREETING", "cart": []}
    },
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Classic Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Delivery",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "22 Kings Avenue",
      "expect": {
        "state": "WAITING_DELIVERY_FEE_APPROVAL",
        "cart": [],
        "response_contains": ["delivery fee", "location"]
      }
    },
    {
      "_type": "staff_action",
      "description": "Staff sets delivery fee R30",
      "context_updates": {
        "delivery_fee_cents": 3000,
        "delivery_fee_status": "FEE_SENT"
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "COLLECTING_PAYMENT",
        "response_contains": ["cash", "card"]
      }
    },
    {
      "message": "Cash",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],

  "final_order": {
    "items": [{"name": "Classic Smash Burger", "quantity": 1}],
    "subtotal_cents": 7500,
    "delivery_fee_cents": 3000,
    "total_cents": 10500,
    "order_mode": "DELIVERY"
  }
}
