{
  "id": "conv_024",
  "title": "Recommendation — What's popular? then accept and order",
  "category": "menu",
  "tags": ["llm", "recommendation", "accept_recommendation"],

  "turns": [
    {
      "message": "Hello",
      "expect": {"state": "GREETING"}
    },
    {
      "message": "What's popular?",
      "llm": {
        "action": "recommend_items",
        "message": "Our most popular items are the Classic Smash Burger (R75) and Ice Coffee (R75)! 😍 Would you like to order those?",
        "items": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Ice Coffee", "quantity": 1}
        ]
      },
      "expect": {
        "state": "BROWSING_MENU",
        "response_contains": ["classic smash burger", "ice coffee"],
        "context_has": {"recommended_items": true}
      }
    },
    {
      "message": "Yes I'll take those",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Ice Coffee", "quantity": 1}
        ],
        "confirmed_cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Ice Coffee", "quantity": 1}
        ],
        "context_has": {"recommended_items": false}
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Ayesha",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0720000002",
      "expect": {"state": "ORDER_PLACED"}
    }
  ],

  "final_order": {
    "items": [
      {"name": "Classic Smash Burger", "quantity": 1},
      {"name": "Ice Coffee", "quantity": 1}
    ],
    "subtotal_cents": 15000,
    "total_cents": 15000,
    "order_mode": "PICKUP"
  }
}
