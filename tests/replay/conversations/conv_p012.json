{
  "id": "conv_p012",
  "title": "Modifier editing — Test 1+2: Burger with Extra Cheese → Remove Extra Cheese",
  "category": "pricing",
  "tags": ["pricing", "add_on", "addon_remove", "det", "llm", "modifier_editing"],

  "notes": "Test 1: order burger with extra cheese (R85 total). Test 2: remove extra cheese via DET — burger stays, price returns to R75. Parent item must never disappear.",

  "menu": ["Loaded Smash Burger", "Coca-Cola (330ml)"],

  "turns": [
    {
      "message": "Can I get a Loaded Smash Burger with extra cheese",
      "llm": {
        "action": "add_items",
        "message": "Added Loaded Smash Burger with Extra Cheese — R85.00 ✅",
        "items": [{"name": "Loaded Smash Burger", "quantity": 1, "options": {}, "add_ons": [{"name": "Extra Cheese", "quantity": 1}], "special_instructions": ""}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Loaded Smash Burger", "quantity": 1}],
        "response_contains": ["loaded smash burger", "extra cheese"]
      }
    },
    {
      "message": "Remove the extra cheese",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Loaded Smash Burger", "quantity": 1}],
        "response_contains": ["removed"]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Thabo",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0821234567",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Loaded Smash Burger", "quantity": 1}],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Thabo"
  }
}
