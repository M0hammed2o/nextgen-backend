{
  "id": "synth_0669",
  "title": "Synth SA greeting \u2014 'Sharp sharp' + Spicy Chicken Burger",
  "category": "synthetic_sa_slang",
  "tags": [
    "synthetic",
    "det",
    "pickup",
    "sa_slang"
  ],
  "turns": [
    {
      "message": "Sharp sharp",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Spicy Chicken Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Spicy Chicken Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Looks good",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Thabo",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0729999999",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Spicy Chicken Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 8000,
    "total_cents": 8000,
    "order_mode": "PICKUP",
    "customer_name": "Thabo"
  }
}