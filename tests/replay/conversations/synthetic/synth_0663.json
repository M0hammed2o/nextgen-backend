  "turns": [
    {
      "message": "Heita bru",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Ice Coffee",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "100",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Priya",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0840000001",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Ice Coffee",
        "quantity": 1
      }
    ],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Priya"
  }
