{
  "id": "synth_0698",
  "title": "Synth SA order \u2014 'Gimme a {}' / Onion Rings",
  "category": "synthetic_sa_slang",
  "tags": [
    "synthetic",
    "det",
    "pickup",
    "sa_slang"
  ],
  "turns": [
    {
      "message": "Gimme a Onion Rings",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Onion Rings",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Place it",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Sipho",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0712345678",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Onion Rings",
        "quantity": 1
      }
    ],
    "subtotal_cents": 3000,
    "total_cents": 3000,
    "order_mode": "PICKUP",
    "customer_name": "Sipho"
  }
}