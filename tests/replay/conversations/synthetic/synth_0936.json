{
  "id": "synth_0936",
  "title": "Synth hours then order \u2014 Ice Coffee",
  "category": "synthetic_business",
  "tags": [
    "synthetic",
    "det",
    "hours",
    "pickup"
  ],
  "turns": [
    {
      "message": "What are your hours?",
      "expect": {
        "state": "IDLE",
        "response_contains": [
          "contact",
          "hours"
        ]
      }
    },
    {
      "message": "Can I get a Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Ice Coffee",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Tariq",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0821234567",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Ice Coffee",
        "quantity": 1
      }
    ],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Tariq"
  }
}