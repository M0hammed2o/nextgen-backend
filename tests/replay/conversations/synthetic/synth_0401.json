{
  "id": "synth_0401",
  "title": "Synth cancel after order \u2014 Spicy Chicken Burger",
  "category": "synthetic_cancel",
  "tags": [
    "synthetic",
    "det",
    "cancel"
  ],
  "turns": [
    {
      "message": "I want a Spicy Chicken Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Spicy Chicken Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Actually never mind",
      "expect": {
        "state": "IDLE",
        "cart": [],
        "response_contains": [
          "cancel",
          "order"
        ]
      }
    }
  ]
}