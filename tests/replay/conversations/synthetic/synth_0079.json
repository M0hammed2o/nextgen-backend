{
  "id": "synth_0079",
  "title": "Synth pickup \u2014 Grilled Chicken Burger \u2014 'Hello'",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Hello",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Grilled Chicken Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Grilled Chicken Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Okay",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pick up",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Lindiwe",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0831111111",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Grilled Chicken Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 8500,
    "total_cents": 8500,
    "order_mode": "PICKUP",
    "customer_name": "Lindiwe"
  }
}