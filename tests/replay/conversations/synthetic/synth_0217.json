{
  "id": "synth_0217",
  "title": "Synth pickup \u2014 Ice Coffee \u2014 'Hi there'",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Hi there",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Ice Coffee",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Yep",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Thabo",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0831111111",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Ice Coffee",
        "quantity": 1
      }
    ],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Thabo"
  }
}