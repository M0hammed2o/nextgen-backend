{
  "id": "synth_1027",
  "title": "Synth pickup (no greeting) \u2014 Chips",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "I'll have a Chips",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Chips",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Perfect",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Brendan",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0834567890",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Chips",
        "quantity": 1
      }
    ],
    "subtotal_cents": 3500,
    "total_cents": 3500,
    "order_mode": "PICKUP",
    "customer_name": "Brendan"
  }
}