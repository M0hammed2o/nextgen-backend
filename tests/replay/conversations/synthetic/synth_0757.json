      }
    },
    {
      "message": "0831111111",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Still Water",
        "quantity": 1
      }
    ],
    "subtotal_cents": 1500,
    "total_cents": 1500,
    "order_mode": "PICKUP",
