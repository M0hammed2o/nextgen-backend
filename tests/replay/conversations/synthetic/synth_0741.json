{
  "id": "synth_0741",
  "title": "Synth SA order \u2014 'I wanna get a {}' / Chips",
  "category": "synthetic_sa_slang",
  "tags": [
    "synthetic",
    "det",
    "pickup",
    "sa_slang"
  ],
  "turns": [
    {
      "message": "I wanna get a Chips",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Chips",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Yep",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Yusuf",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0834567890",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Chips",
        "quantity": 1
      }
    ],
    "subtotal_cents": 3500,
    "total_cents": 3500,
    "order_mode": "PICKUP",
    "customer_name": "Yusuf"
  }
}