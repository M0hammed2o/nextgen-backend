{
  "id": "synth_0670",
  "title": "Synth SA greeting \u2014 'Sharp sharp' + Double Smash Burger",
  "category": "synthetic_sa_slang",
  "tags": [
    "synthetic",
    "det",
    "pickup",
    "sa_slang"
  ],
  "turns": [
    {
      "message": "Sharp sharp",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Double Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Double Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "OK",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Lindiwe",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0840000001",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Double Smash Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP",
    "customer_name": "Lindiwe"
  }
}