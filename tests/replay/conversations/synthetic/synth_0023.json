{
  "id": "synth_0023",
  "title": "Synth pickup \u2014 Double Smash Burger \u2014 'Good evening'",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Good evening",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Double Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Double Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Looks good",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pick up",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Fatima",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0831234567",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Double Smash Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP",
    "customer_name": "Fatima"
  }
}