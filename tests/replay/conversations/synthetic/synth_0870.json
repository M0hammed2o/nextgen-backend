{
  "id": "synth_0870",
  "title": "Synth view cart then confirm \u2014 Grilled Chicken Burger",
  "category": "synthetic_cart",
  "tags": [
    "synthetic",
    "det",
    "cart",
    "pickup"
  ],
  "turns": [
    {
      "message": "Can I get a Grilled Chicken Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Grilled Chicken Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "What's in my cart?",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "response_contains": [
          "grilled chicken burger"
        ]
      }
    },
    {
      "message": "Yeah",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Pieter",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0821234567",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Grilled Chicken Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 8500,
    "total_cents": 8500,
    "order_mode": "PICKUP",
    "customer_name": "Pieter"
  }
}