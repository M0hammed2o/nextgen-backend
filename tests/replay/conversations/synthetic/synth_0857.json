{
  "id": "synth_0857",
  "title": "Synth no-change then cancel \u2014 Coca-Cola (330ml)",
  "category": "synthetic_cancel",
  "tags": [
    "synthetic",
    "det",
    "cancel",
    "no_change"
  ],
  "turns": [
    {
      "message": "Can I get a Coca-Cola (330ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
