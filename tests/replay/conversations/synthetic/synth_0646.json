{
  "id": "synth_0646",
  "title": "Synth browse+cancel \u2014 'Howzit'/'What food do you have?'",
  "category": "synthetic_browse",
  "tags": [
    "synthetic",
    "det",
    "browse",
    "cancel"
  ],
  "turns": [
    {
      "message": "Howzit",
      "expect": {
        "state": "GREETING",
