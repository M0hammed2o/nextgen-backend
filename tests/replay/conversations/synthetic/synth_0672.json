    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Tariq",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0831111111",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Grilled Chicken Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 8500,
    "total_cents": 8500,
    "order_mode": "PICKUP",
