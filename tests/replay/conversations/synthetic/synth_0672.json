{
  "id": "synth_0672",
  "title": "Synth SA greeting \u2014 'Sharp sharp' + Grilled Chicken Burger",
  "category": "synthetic_sa_slang",
  "tags": [
    "synthetic",
    "det",
    "pickup",
    "sa_slang"
