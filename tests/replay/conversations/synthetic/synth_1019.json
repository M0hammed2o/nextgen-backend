{
  "id": "synth_1019",
  "title": "Synth pickup (no greeting) \u2014 Onion Rings",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "I'd like a Onion Rings",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Onion Rings",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Done",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Zanele",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0729876543",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Onion Rings",
        "quantity": 1
      }
    ],
    "subtotal_cents": 3000,
    "total_cents": 3000,
    "order_mode": "PICKUP",
    "customer_name": "Zanele"
  }
}