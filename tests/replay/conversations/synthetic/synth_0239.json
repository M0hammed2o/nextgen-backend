{
  "id": "synth_0239",
  "title": "Synth pickup (no greeting) \u2014 Double Smash Burger",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Can I get a Double Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Double Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Lekker",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup please",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Nompilo",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0611111111",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Double Smash Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP",
    "customer_name": "Nompilo"
  }
}