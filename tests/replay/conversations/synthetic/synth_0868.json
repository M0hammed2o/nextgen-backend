{
  "id": "synth_0868",
  "title": "Synth view cart then confirm \u2014 Coca-Cola (330ml)",
  "category": "synthetic_cart",
  "tags": [
    "synthetic",
    "det",
    "cart",
    "pickup"
  ],
  "turns": [
    {
      "message": "Can I get a Coca-Cola (330ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Coca-Cola (330ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Show my cart",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "response_contains": [
          "coca-cola (330ml)"
        ]
      }
    },
    {
      "message": "Sure",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Thabo",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0840000001",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Coca-Cola (330ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 2000,
    "total_cents": 2000,
    "order_mode": "PICKUP",
    "customer_name": "Thabo"
  }
}