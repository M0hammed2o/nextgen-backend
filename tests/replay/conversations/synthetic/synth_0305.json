{
  "id": "synth_0305",
  "title": "Synth pickup (no greeting) \u2014 Coca-Cola (500ml)",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Can I get a Coca-Cola (500ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Coca-Cola (500ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Sure",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Collect",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Pieter",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0729876543",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Coca-Cola (500ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 2500,
    "total_cents": 2500,
    "order_mode": "PICKUP",
    "customer_name": "Pieter"
  }
}