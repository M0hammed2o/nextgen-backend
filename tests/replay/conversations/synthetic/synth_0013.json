{
  "id": "synth_0013",
  "title": "Synth pickup \u2014 Classic Smash Burger \u2014 'Hi'",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Hi",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Correct",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Collect",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Kgotso",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0729999999",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Classic Smash Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Kgotso"
  }
}