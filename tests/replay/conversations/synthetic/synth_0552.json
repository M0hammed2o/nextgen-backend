{
  "id": "synth_0552",
  "title": "Synth cancel after confirm \u2014 Classic Smash Burger",
  "category": "synthetic_cancel",
  "tags": [
    "synthetic",
    "det",
    "cancel"
  ],
  "turns": [
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Yeah",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Scratch that",
      "expect": {
        "state": "IDLE",
        "cart": [],
        "response_contains": [
          "cancel",
          "order"
        ]
      }
    }
  ]
}