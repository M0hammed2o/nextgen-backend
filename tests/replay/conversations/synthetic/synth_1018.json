{
  "id": "synth_1018",
  "title": "Synth pickup (no greeting) \u2014 Sprite (330ml)",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Give me a Sprite (330ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Sprite (330ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Done",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Thabo",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0834567890",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Sprite (330ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 2000,
    "total_cents": 2000,
    "order_mode": "PICKUP",
    "customer_name": "Thabo"
  }
}