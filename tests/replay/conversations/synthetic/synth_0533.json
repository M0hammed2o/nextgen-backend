{
  "id": "synth_0533",
  "title": "Synth cancel after order \u2014 Ice Coffee",
  "category": "synthetic_cancel",
  "tags": [
    "synthetic",
    "det",
    "cancel"
  ],
  "turns": [
    {
      "message": "Can I get a Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Ice Coffee",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Cancel",
      "expect": {
        "state": "IDLE",
        "cart": [],
        "response_contains": [
          "cancel",
          "order"
        ]
      }
    }
  ]
}