{
  "id": "synth_0935",
  "title": "Synth hours then order \u2014 Grilled Chicken Burger",
  "category": "synthetic_business",
  "tags": [
    "synthetic",
    "det",
    "hours",
    "pickup"
  ],
  "turns": [
    {
      "message": "Store hours?",
      "expect": {
        "state": "IDLE",
        "response_contains": [
          "contact",
          "hours"
        ]
      }
    },
    {
      "message": "Can I get a Grilled Chicken Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Grilled Chicken Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Riya",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0821000001",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Grilled Chicken Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 8500,
    "total_cents": 8500,
    "order_mode": "PICKUP",
    "customer_name": "Riya"
  }
}