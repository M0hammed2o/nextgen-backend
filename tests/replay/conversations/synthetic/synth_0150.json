{
  "id": "synth_0150",
  "title": "Synth pickup \u2014 Coca-Cola (500ml) \u2014 'Sawubona'",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Sawubona",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Coca-Cola (500ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Coca-Cola (500ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Sharp",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup please",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Thabo",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0611111111",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Coca-Cola (500ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 2500,
    "total_cents": 2500,
    "order_mode": "PICKUP",
    "customer_name": "Thabo"
  }
}