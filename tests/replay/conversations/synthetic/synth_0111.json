{
  "id": "synth_0111",
  "title": "Synth pickup \u2014 Onion Rings \u2014 'Hello'",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Hello",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Onion Rings",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Onion Rings",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Perfect",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup please",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Brendan",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0712345678",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Onion Rings",
        "quantity": 1
      }
    ],
    "subtotal_cents": 3000,
    "total_cents": 3000,
    "order_mode": "PICKUP",
    "customer_name": "Brendan"
  }
}