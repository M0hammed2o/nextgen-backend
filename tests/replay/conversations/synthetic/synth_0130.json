{
  "id": "synth_0130",
  "title": "Synth pickup \u2014 Coca-Cola (330ml) \u2014 'Good morning'",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "Good morning",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Coca-Cola (330ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Coca-Cola (330ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Perfect",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Ahmed",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0840000001",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Coca-Cola (330ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 2000,
    "total_cents": 2000,
    "order_mode": "PICKUP",
    "customer_name": "Ahmed"
  }
}