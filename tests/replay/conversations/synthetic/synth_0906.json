{
  "id": "synth_0906",
  "title": "Synth coffee pickup \u2014 Cappuccino almond milk \u2014 'Morning'",
  "category": "synthetic_options",
  "tags": [
    "synthetic",
    "det",
    "pickup",
    "options",
    "coffee"
  ],
  "turns": [
    {
      "message": "Morning",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Cappuccino with almond milk",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Cappuccino",
            "quantity": 1,
            "special_instructions": "almond milk"
          }
        ]
      }
    },
    {
      "message": "Perfect",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Ntombi",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0712345678",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Cappuccino",
        "quantity": 1
      }
    ],
    "subtotal_cents": 4500,
    "total_cents": 4500,
    "order_mode": "PICKUP",
    "customer_name": "Ntombi"
  }
}