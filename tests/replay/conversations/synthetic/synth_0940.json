{
  "id": "synth_0940",
  "title": "Synth hours then order \u2014 Spicy Chicken Burger",
  "category": "synthetic_business",
  "tags": [
    "synthetic",
    "det",
    "hours",
    "pickup"
  ],
  "turns": [
    {
      "message": "When do you close?",
      "expect": {
        "state": "IDLE",
        "response_contains": [
          "contact",
          "hours"
        ]
      }
    },
    {
      "message": "Can I get a Spicy Chicken Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Spicy Chicken Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Pieter",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0712345678",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Spicy Chicken Burger",
        "quantity": 1
      }
    ],
    "subtotal_cents": 8000,
    "total_cents": 8000,
    "order_mode": "PICKUP",
    "customer_name": "Pieter"
  }
}