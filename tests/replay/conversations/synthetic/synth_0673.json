{
  "id": "synth_0673",
  "title": "Synth SA greeting \u2014 'Sharp sharp' + Coca-Cola (500ml)",
  "category": "synthetic_sa_slang",
  "tags": [
    "synthetic",
    "det",
    "pickup",
    "sa_slang"
