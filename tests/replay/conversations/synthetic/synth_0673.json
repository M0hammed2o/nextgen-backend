          {
            "name": "Coca-Cola (500ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Okay",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Pieter",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0821000001",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Coca-Cola (500ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 2500,
    "total_cents": 2500,
    "order_mode": "PICKUP",
    "customer_name": "Pieter"
