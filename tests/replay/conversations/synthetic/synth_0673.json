  "turns": [
    {
      "message": "Sharp sharp",
      "expect": {
        "state": "GREETING",
        "cart": [],
        "response_contains": [
          "welcome"
        ]
      }
    },
    {
      "message": "Can I get a Coca-Cola (500ml)",
      "expect": {
        "state": "CONFIRMING_ORDER",
