{
  "id": "synth_1011",
  "title": "Synth pickup (no greeting) \u2014 Ice Coffee",
  "category": "synthetic_pickup",
  "tags": [
    "synthetic",
    "det",
    "pickup"
  ],
  "turns": [
    {
      "message": "I want a Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Ice Coffee",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "Place it",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Yusuf",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0729876543",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Ice Coffee",
        "quantity": 1
      }
    ],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP",
    "customer_name": "Yusuf"
  }
}