{
  "id": "conv_302",
  "title": "Options — full flow: DET asks required option, LLM resolves, order placed",
  "category": "options",
  "tags": ["det", "llm", "options", "required_options", "pickup", "cx"],

  "turns": [
    {
      "message": "Can I get a cappuccino",
      "expect": {
        "state": "CHOOSING_OPTIONS",
        "cart": [],
        "response_contains": ["milk", "cappuccino", "oat", "soy"]
      }
    },
    {
      "message": "Oat milk please",
      "llm": {
        "action": "add_items",
        "message": "Added Cappuccino with oat milk! ✅",
        "items": [{"name": "Cappuccino", "quantity": 1, "special_instructions": "oat milk"}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Cappuccino", "quantity": 1, "special_instructions": "oat milk"}]
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Mohammed",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0837866021",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],

  "final_order": {
    "items": [{"name": "Cappuccino", "quantity": 1, "special_instructions": "oat milk"}],
    "subtotal_cents": 4500,
    "total_cents": 4500,
    "order_mode": "PICKUP",
    "customer_name": "Mohammed"
  }
}
