{
  "id": "conv_031",
  "title": "Extra ingredient modifier — with extra cheese",
  "category": "modifiers",
  "tags": ["deterministic", "extra_ingredient", "suffix_extraction"],

  "turns": [
    {
      "message": "Can I get a Classic Smash Burger with extra cheese",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "extra cheese"}],
        "confirmed_cart": [{"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "extra cheese"}]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Precious",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0710000007",
      "expect": {"state": "ORDER_PLACED"}
    }
  ],

  "final_order": {
    "items": [{"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "extra cheese"}],
    "subtotal_cents": 7500,
    "total_cents": 7500,
    "order_mode": "PICKUP"
  }
}
