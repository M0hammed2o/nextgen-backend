{
  "id": "conv_086",
  "title": "Pickup — Business requires phone only (name not required)",
  "category": "pickup",
  "tags": ["deterministic", "pickup", "phone_only"],

  "business": {
    "require_customer_name": false,
    "require_phone_number": true
  },

  "turns": [
    {
      "message": "Can I get a Double Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Double Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS",
        "response_contains": ["phone"]
      }
    },
    {
      "message": "0811000001",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Double Smash Burger", "quantity": 1}],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP"
  }
}
