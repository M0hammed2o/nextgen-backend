{
  "id": "conv_p014",
  "title": "Modifier editing — Test 4: Burger with Extra Cheese → Replace with Extra Patty",
  "category": "pricing",
  "tags": ["pricing", "add_on", "addon_replace", "llm", "modifier_editing"],

  "notes": "Burger with Extra Cheese (R85). Customer says 'replace the extra cheese with an extra patty'. LLM returns replace_item with add_ons=[Extra Patty]. Burger stays. Price becomes R100. Cart must never be empty.",

  "menu": ["Loaded Smash Burger"],

  "turns": [
    {
      "message": "Loaded Smash Burger with extra cheese please",
      "llm": {
        "action": "add_items",
        "message": "Loaded Smash Burger with Extra Cheese — R85.00 ✅",
        "items": [{"name": "Loaded Smash Burger", "quantity": 1, "options": {}, "add_ons": [{"name": "Extra Cheese", "quantity": 1}], "special_instructions": ""}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Loaded Smash Burger", "quantity": 1}]
      }
    },
    {
      "message": "Replace the extra cheese with an extra patty",
      "llm": {
        "action": "replace_item",
        "message": "Done — swapped Extra Cheese for Extra Patty. Total is now R100.00.",
        "items": [{"remove": "Loaded Smash Burger", "add": "Loaded Smash Burger", "quantity": 1, "options": {}, "add_ons": [{"name": "Extra Patty", "quantity": 1}], "special_instructions": ""}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Loaded Smash Burger", "quantity": 1}],
        "response_contains": ["extra patty"]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Kabelo",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0824567890",
      "expect": {"state": "ORDER_PLACED", "cart": []}
    }
  ],

  "final_order": {
    "items": [{"name": "Loaded Smash Burger", "quantity": 1}],
    "subtotal_cents": 10000,
    "total_cents": 10000,
    "order_mode": "PICKUP",
    "customer_name": "Kabelo"
  }
}
