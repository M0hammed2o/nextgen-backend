{
  "id": "conv_043",
  "title": "Confirmation \u2014 Wait then add, then confirm",
  "category": "confirmation",
  "tags": [
    "deterministic",
    "negation",
    "edit_after_confirm"
  ],
  "turns": [
    {
      "message": "Can I get a Classic Smash Burger",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "No",
      "expect": {
        "state": "BUILDING_CART",
        "response_contains": [
          "change"
        ]
      }
    },
    {
      "message": "Add a Coke",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {
            "name": "Classic Smash Burger",
            "quantity": 1
          },
          {
            "name": "Coca-Cola (330ml)",
            "quantity": 1
          }
        ]
      }
    },
    {
      "message": "That's it",
      "expect": {
        "state": "CHOOSING_ORDER_MODE"
      }
    },
    {
      "message": "Pickup",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "Phindi",
      "expect": {
        "state": "COLLECTING_DETAILS"
      }
    },
    {
      "message": "0720000017",
      "expect": {
        "state": "ORDER_PLACED"
      }
    }
  ],
  "final_order": {
    "items": [
      {
        "name": "Classic Smash Burger",
        "quantity": 1
      },
      {
        "name": "Coca-Cola (330ml)",
        "quantity": 1
      }
    ],
    "subtotal_cents": 9500,
    "total_cents": 9500,
    "order_mode": "PICKUP"
  }
}