{
  "id": "conv_034",
  "title": "QMS applied twice — 2 CSBs then 1 no tomato then 1 no onion",
  "category": "modifiers",
  "tags": ["deterministic", "quantity_modifier_split", "multi_modifier"],

  "turns": [
    {
      "message": "2 Classic Smash Burgers",
      "llm": {
        "action": "add_items",
        "message": "Added 2x Classic Smash Burger ✅",
        "items": [{"name": "Classic Smash Burger", "quantity": 2}]
      },
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Classic Smash Burger", "quantity": 2}]
      }
    },
    {
      "message": "1 no tomato",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {"name": "Classic Smash Burger", "quantity": 1},
          {"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "no tomato"}
        ]
      }
    },
    {
      "message": "1 no onion",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [
          {"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "no tomato"},
          {"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "no onion"}
        ]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Pickup",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "Lungelo",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "0710000010",
      "expect": {"state": "ORDER_PLACED"}
    }
  ],

  "final_order": {
    "items": [
      {"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "no tomato"},
      {"name": "Classic Smash Burger", "quantity": 1, "special_instructions": "no onion"}
    ],
    "subtotal_cents": 15000,
    "total_cents": 15000,
    "order_mode": "PICKUP"
  }
}
