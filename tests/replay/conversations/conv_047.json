{
  "id": "conv_047",
  "title": "Delivery with card payment",
  "category": "delivery",
  "tags": ["deterministic", "delivery", "card_payment"],

  "business": {
    "delivery_enabled": true,
    "require_customer_name": false,
    "require_phone_number": false
  },

  "turns": [
    {
      "message": "Can I get an Ice Coffee",
      "expect": {
        "state": "CONFIRMING_ORDER",
        "cart": [{"name": "Ice Coffee", "quantity": 1}]
      }
    },
    {
      "message": "Yes",
      "expect": {"state": "CHOOSING_ORDER_MODE"}
    },
    {
      "message": "Delivery",
      "expect": {"state": "COLLECTING_DETAILS"}
    },
    {
      "message": "5 Rivonia Road, Sandton",
      "expect": {
        "state": "WAITING_DELIVERY_FEE_APPROVAL",
        "cart": [],
        "context_has": {"pending_order_id": true}
      }
    },
    {
      "_type": "staff_action",
      "description": "Staff sets R20 delivery fee",
      "context_updates": {
        "delivery_fee_cents": 2000,
        "delivery_fee_status": "FEE_SENT"
      }
    },
    {
      "message": "Yes",
      "expect": {
        "state": "COLLECTING_PAYMENT",
        "response_contains": ["cash", "card"]
      }
    },
    {
      "message": "Card",
      "expect": {
        "state": "ORDER_PLACED",
        "cart": []
      }
    }
  ],

  "final_order": {
    "items": [{"name": "Ice Coffee", "quantity": 1}],
    "subtotal_cents": 7500,
    "delivery_fee_cents": 2000,
    "total_cents": 9500,
    "order_mode": "DELIVERY",
    "payment_status": "PENDING"
  }
}
